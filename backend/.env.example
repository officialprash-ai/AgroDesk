# Copy to .env and fill in values
DATABASE_URL="postgresql://user:password@host:5432/agrodesk"
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
JWT_SECRET="change-this-to-a-random-64-char-string"
PORT=3001
NODE_ENV=production

FRONTEND_URL="https://your-production-frontend.vercel.app"
BACKEND_URL="https://agrodesk-production.up.railway.app"  # Used by worker to build ExoML/audio URLs

# Webhook security (required in production)
TWILIO_AUTH_TOKEN=           # From Twilio Console — used to validate /api/webhooks/* signatures
TWILIO_ACCOUNT_SID=          # From Twilio Console — needed for outbound WhatsApp
EXOTEL_WEBHOOK_TOKEN=        # A random secret you set in Exotel dashboard as the webhook passthru token

# Optional integrations
REDIS_URL=                   # Required for the queue/worker (Bull) — get one from Railway/Upstash
EXOTEL_API_KEY=              # Exotel Console → API Settings
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_PHONE=                # Your Exotel virtual number, e.g. 08049XXXXXX
SARVAM_API_KEY=              # console.sarvam.ai — Marathi/Indian-language TTS for voice calls
WHATSAPP_PHONE_ID=           # Your Twilio WhatsApp sender number, digits only e.g. 91XXXXXXXXXX
MSG91_AUTH_KEY=              # msg91.com — for DLT-compliant SMS
MSG91_SENDER_ID=             # 6-char DLT-registered sender ID (defaults to AGRODS)

# DLT template IDs — register each SMS template on the TRAI DLT / MSG91 portal first.
# SMS sends will fail with a clear error until these are filled in.
DLT_TPL_COLD_FOLLOWUP=
DLT_TPL_RECOVERY_GENTLE=
DLT_TPL_RECOVERY_FIRM=
DLT_TPL_WA_UNAVAILABLE=
DLT_TPL_SUPPORT_NOTIFY=      # Support Intake: SMS fallback alerting staff to a new service/repair request

# Google Sign-In (optional)
GOOGLE_CLIENT_ID=

# AWS S3 — optional, for AI Accountant bill storage. Without these, uploaded bills
# are stored inline in Postgres (fine for MVP volumes, not for scale).
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET=
AWS_REGION=ap-south-1

# Sentry — optional but recommended for production
SENTRY_DSN=                  # From sentry.io project settings → Client Keys → DSN

# ─── Real-time voice (Plivo streaming + Sarvam STT/TTS + Gemini) ───
# NEW: bidirectional AI voice calls. Plivo is primary; Exotel streaming is a stub.
VOICE_CALL_MODE=streaming                # streaming (Plivo live AI voice) | oneway (legacy Exotel <Play>)
TELEPHONY_PROVIDER=plivo                 # plivo | exotel
TELEPHONY_PUBLIC_WSS_URL=                # wss://<backend-host>/telephony/stream
PLIVO_AUTH_ID=                           # Plivo Console → Account
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=                       # Plivo number, E.164 e.g. +9198XXXXXXXX
# VOICE_SYSTEM_PROMPT=                    # optional persona override for the voice agent
VOICE_TTS_MODE=streaming                 # streaming (Sarvam TTS WebSocket, low latency) | rest (blocking)
# SARVAM_TTS_MODEL=bulbul:v2             # bulbul:v2 (pitch/loudness) | bulbul:v3 (more voices)
# SARVAM_TTS_SPEAKER=anushka             # voice; must exist for the chosen model
# SARVAM_TTS_PACE=0.95                   # 0.3-3.0 on v2; slightly under 1 reads naturally on a call
# STT/TTS reuse SARVAM_API_KEY above; the voice LLM reuses GEMINI_API_KEY/GEMINI_MODEL.

# ─── Support Intake module ──────────────────────────────────────────────────
SUPPORT_VOICE_TOKEN=                     # Shared secret appended to the Plivo voice IVR webhooks
                                         #   (?token=…). Required in production or the routes 503.
WHATSAPP_TPL_SUPPORT_NOTIFY=             # Twilio Content SID ("HX…") of the Meta-APPROVED template
                                         #   used to alert the mechanic/technician of a new request.
                                         #   Without it, staff alerts only deliver inside WhatsApp's
                                         #   24-hour service window (then fall back to DLT SMS).
                                         #   Template needs 5 variables:
                                         #   {{1}} type  {{2}} customer  {{3}} phone  {{4}} note  {{5}} link
# Reuses: TWILIO_*, WHATSAPP_PHONE_ID, SARVAM_API_KEY (voice-note transcription),
#         AWS_* (photo storage), FRONTEND_URL (deep link in the staff alert).
