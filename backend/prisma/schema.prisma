generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Dealer {
  id           String   @id @default(cuid())
  name         String
  city         String
  district     String
  state        String   @default("Maharashtra")
  gst_number   String?
  phone        String
  email        String?
  language     String   @default("mr")
  plan          String   @default("growth")
  password_hash String   @default("")
  google_id     String?  @unique
  is_demo       Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at   DateTime @updatedAt

  // ─── Org onboarding / setup ────────────────────────────────
  brand_ids         String[] @default([])   // Brand.id values this dealer sells (new + used)
  business_type     String?                 // authorized_dealer | reseller | both
  onboarding_status String   @default("active") // draft (mid-setup) | active (setup complete)
  onboarding_step   Int      @default(0)    // last wizard step completed, for resuming
  gst_verified      Boolean  @default(false)
  logo_url          String?

  contacts     Contact[]
  campaigns    Campaign[]
  tractors     UsedTractor[]
  recovery     RecoveryCase[]
  documents    Document[]
  accountants  Accountant[]
  agent_jobs   AgentJob[]
  // ─── Support Intake module ─────────────────────────────────
  machines         Machine[]
  support_requests SupportRequest[]
  support_routing  SupportRouting?
  @@map("dealers")
}

// Tractor brand catalog — shared reference list used by the onboarding wizard
// and (eventually) inventory/listing forms. Not dealer-scoped.
model Brand {
  id         String   @id @default(cuid())
  name       String   @unique
  category   String   @default("tractor") // tractor | implement
  logo_url   String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  @@map("brands")
}

model Contact {
  id                String    @id @default(cuid())
  dealer_id         String
  name              String
  phone             String
  email             String?
  village           String?
  district          String?
  state             String?
  language          String    @default("mr")
  lead_status       String    @default("new")
  score             Int       @default(0)
  tags              String[]
  last_contact      DateTime?
  opt_in_whatsapp   Boolean   @default(false)
  opt_in_sms        Boolean   @default(false)
  opt_in_call       Boolean   @default(false)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  dealer            Dealer    @relation(fields: [dealer_id], references: [id])
  consents          Consent[]
  conversations     Conversation[]
  campaigns         CampaignContact[]
  machines          Machine[]
  support_requests  SupportRequest[]
  @@map("contacts")
}

model UsedTractor {
  id            String   @id @default(cuid())
  dealer_id     String
  make          String
  model         String
  year          Int
  hours         Int
  asking_price  Int
  cost_price    Int
  days_on_lot   Int      @default(0)
  urgency_score Int      @default(0)
  condition     String   @default("good")
  description   String?
  ai_description String?
  photos        String[]
  status        String   @default("available")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  dealer        Dealer   @relation(fields: [dealer_id], references: [id])
  @@map("used_tractors")
}

model Campaign {
  id              String   @id @default(cuid())
  dealer_id       String
  name            String
  goal            String
  channels        String[]
  status          String   @default("idle")
  total_contacts  Int      @default(0)
  sent            Int      @default(0)
  responses       Int      @default(0)
  interested      Int      @default(0)
  language        String   @default("mr")
  script_voice    String?
  script_whatsapp String?
  script_sms      String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  dealer          Dealer   @relation(fields: [dealer_id], references: [id])
  contacts        CampaignContact[]
  @@map("campaigns")
}

// Individual contacts explicitly attached to a campaign (single-add or CSV import),
// as opposed to total_contacts which is just the aggregate counter shown in the UI.
model CampaignContact {
  id          String   @id @default(cuid())
  campaign_id String
  contact_id  String
  created_at  DateTime @default(now())

  campaign    Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  contact     Contact  @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  @@unique([campaign_id, contact_id])
  @@index([campaign_id])
  @@map("campaign_contacts")
}

model RecoveryCase {
  id                String   @id @default(cuid())
  dealer_id         String
  customer_name     String
  phone             String
  amount_due        Int
  due_date          DateTime
  escalation_stage  String   @default("gentle")
  last_contact      DateTime?
  ptp_date          DateTime?
  ptp_amount        Int?
  status            String   @default("active")
  channel_history   Json     @default("[]")
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  dealer            Dealer   @relation(fields: [dealer_id], references: [id])
  @@map("recovery_cases")
}

model Document {
  id            String   @id @default(cuid())
  dealer_id     String
  category      String
  period_month  String
  file_url      String?
  filename      String?
  ocr_data      Json?
  confirmed     Boolean  @default(false)
  tally_synced  Boolean  @default(false)
  uploaded_at   DateTime?
  created_at    DateTime @default(now())

  dealer        Dealer   @relation(fields: [dealer_id], references: [id])
  @@map("documents")
}

model Accountant {
  id             String  @id @default(cuid())
  dealer_id      String
  name           String
  phone          String
  email          String
  tally_enabled  Boolean @default(false)
  is_default     Boolean @default(false)
  created_at     DateTime @default(now())

  dealer         Dealer  @relation(fields: [dealer_id], references: [id])
  @@map("accountants")
}

model Consent {
  id          String   @id @default(cuid())
  dealer_id   String
  contact_id  String
  channel     String
  opt_in_at   DateTime?
  opt_out_at  DateTime?
  source      String?
  created_at  DateTime @default(now())

  contact     Contact  @relation(fields: [contact_id], references: [id])
  @@map("consents")
}

model AgentJob {
  id               String   @id @default(cuid())
  dealer_id        String
  agent_type       String
  payload          Json     @default("{}")
  status           String   @default("pending")
  attempts         Int      @default(0)
  scheduled_for    DateTime @default(now())
  completed_at     DateTime?
  error            String?
  idempotency_key  String   @unique
  created_at       DateTime @default(now())

  dealer           Dealer   @relation(fields: [dealer_id], references: [id])
  @@index([dealer_id, agent_type, status])
  @@map("agent_jobs")
}

model Conversation {
  id           String   @id @default(cuid())
  dealer_id    String
  contact_id   String
  campaign_id  String?
  channel      String   // whatsapp | voice | sms | email
  direction    String   // inbound | outbound
  content      String   // message text or call transcript/summary
  status       String   @default("delivered") // sent | delivered | read | failed | answered | missed
  sentiment    String?  // positive | neutral | negative (AI-labelled)
  intent       String?  // interested | not_interested | callback | info_request | complaint
  duration_sec Int?     // for voice calls
  media_url    String?  // for WhatsApp media messages
  twilio_sid   String?  @unique // Twilio MessageSid or CallSid
  created_at   DateTime @default(now())

  contact      Contact  @relation(fields: [contact_id], references: [id])
  @@index([dealer_id, contact_id, created_at])
  @@index([dealer_id, campaign_id])
  @@index([twilio_sid])
  @@map("conversations")
}

// ─── Ops (Vault) console: persisted admin accounts + audit trail ───
// Previously in-memory in agrodesk Ops--backend/src/routes/admin.ts (wiped on restart).
model AdminUser {
  id            String    @id @default(cuid())
  username      String    @unique
  password_hash String
  role          String    @default("viewer") // superadmin | admin | viewer
  totp_secret   String?
  totp_enabled  Boolean   @default(false)
  last_login    DateTime?
  last_ip       String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  @@map("admin_users")
}

model AuditLog {
  id       Int      @id @default(autoincrement())
  ts       DateTime @default(now())
  user     String
  ip       String
  action   String
  resource String
  detail   String
  severity String   @default("info")

  @@index([ts])
  @@map("audit_log")
}

// ─── Support Intake module ───────────────────────────────────
// Captures every service / repair / enquiry request that arrives by phone or
// WhatsApp as a ticket BEFORE any call transfer, so a request is never lost.
//
// Note on conventions (matches the rest of this schema):
//  - The "customer" is the existing `Contact` model — there is no separate
//    Customer table. `contact_id` is null when the caller is unknown.
//  - status / type / channel / routed_to are TEXT columns with documented
//    string unions (same style as Conversation.status/channel), not PG enums.
//  - Tenant isolation is application-level via `dealer_id` (see routes), the
//    same pattern used everywhere else — there is no Postgres RLS in this repo.

// A tractor owned by a Contact. Lets a ticket be tied to a specific machine
// when the caller/AI identifies it unambiguously.
model Machine {
  id            String    @id @default(cuid())
  dealer_id     String
  contact_id    String
  make          String
  model         String
  reg_no        String?
  chassis_no    String?
  delivery_date DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  dealer   Dealer           @relation(fields: [dealer_id], references: [id])
  contact  Contact          @relation(fields: [contact_id], references: [id])
  requests SupportRequest[]

  @@index([dealer_id])
  @@index([contact_id])
  @@index([reg_no])
  @@map("machines")
}

// The support ticket. Created first, always — transfer/notify happens after.
model SupportRequest {
  id          String  @id @default(cuid())
  dealer_id   String
  contact_id  String? // null when the caller is unknown
  machine_id  String?
  phone       String  // always present — the source of truth for identity
  caller_name String? // captured by AI when the contact is unknown

  type    String // SERVICE | REPAIR | OTHER | UNSURE
  status  String @default("NEW") // NEW | SEEN | IN_PROGRESS | DONE
  channel String // CALL | WHATSAPP | MANUAL

  note    String  // verbatim, in Marathi
  note_en String? // optional translation for search

  routed_to        String?  // MECHANIC | TECHNICIAN | DEALER
  routed_to_phone  String?
  transferred      Boolean  @default(false) // did the handoff actually connect?

  external_call_id String?  @unique // Plivo call UUID / WhatsApp message id — idempotency key
  media_urls       String[] @default([]) // WhatsApp photos

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  seen_at    DateTime?
  closed_at  DateTime?

  dealer  Dealer   @relation(fields: [dealer_id], references: [id])
  contact Contact? @relation(fields: [contact_id], references: [id])
  machine Machine? @relation(fields: [machine_id], references: [id])

  @@index([dealer_id, status])
  @@index([dealer_id, type])
  @@index([dealer_id, created_at])
  @@index([phone])
  @@map("support_requests")
}

// Per-dealer routing targets + office hours (IST, 24h "HH:MM").
model SupportRouting {
  id                 String   @id @default(cuid())
  dealer_id          String   @unique
  mechanic_phone     String?
  technician_phone   String?
  dealer_phone       String?
  office_hours_start String   @default("09:00")
  office_hours_end   String   @default("19:00")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  dealer Dealer @relation(fields: [dealer_id], references: [id])
  @@map("support_routing")
}
